pkgname=electron
pkgver=35
pkgrel=1
epoch=1
pkgdesc='Meta package providing the latest available stable Electron build'
arch=(any)
url='https://electronjs.org'
license=(MIT)
depends=("electron$pkgver")

package() {
  mkdir -p "$pkgdir/usr/bin" "$pkgdir/usr/lib"
  ln -sf "${pkgname}${pkgver}" "$pkgdir/usr/bin/$pkgname"
  ln -sf "${pkgname}${pkgver}" "$pkgdir/usr/lib/$pkgname"
}

pre_install() {
	log "Iniciando instalação"
}

post_install() {
	log "Finalizando instalação"
}

pre_upgrade() {
	log "Iniciando upgrade"
}

post_upgrade() {
	log "Finalizando upgrade"
}
