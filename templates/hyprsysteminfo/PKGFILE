pkgname=hyprsysteminfo
pkgver=0.2.0
pkgrel=2
pkgdesc="A tiny qt6/qml application to display information about the running system"
arch=(x86_64)
url="https://github.com/hyprwm/hyprsysteminfo"
license=('BSD-3-Clause')
depends=(
	hyprtoolkit
	hyprutils
	pciutils
)
makedepends=(
  pkgconf
  qt6-base
  qt6-declarative-devel
	cmake
	glaze
  hyprland-qt-support
  hyprutils
  qt6-base-devel
  qt6-base-private-devel
  qt6-declarative-devel
  qt6-declarative-private-devel
  qt6-tools-devel
  qt6-wayland-devel
  qt6-wayland-private-devel
  glaze
  hyprtoolkit
  pciutils-devel
)
conflicts=()
#source=("https://github.com/hyprwm/${pkgname}/archive/refs/tags/v${pkgver}.tar.gz")
#sha256sums=('4f875e7e986deeda35c05090b59f11f3b5802cac8863dafcc6e8251ea37530b1')
source="https://github.com/hyprwm/hyprsysteminfo/archive/refs/tags/v${pkgver}.tar.gz"
checksum=4f875e7e986deeda35c05090b59f11f3b5802cac8863dafcc6e8251ea37530b1

prepare() {
    cd "${srcdir}/${pkgname}-${pkgver}" || exit 1

    echo "PWD=$(pwd)"
    ls -la
    find . -maxdepth 2 -name CMakeLists.txt

    patch -Np1 -i ../../patches/0001-replace-embed-with-include.patch
    patch -Np1 -i ../../patches/0002-qt6-wayland-private.patch

    xxd -i -n HYPRLAND_LOGO_BYTES resource/hyprlandlogo.svg > src/icons/hyprlandlogo.hpp
}

build() {
	cd "${srcdir}/${pkgname}-${pkgver}"
	cmake --no-warn-unused-cli \
		-D CMAKE_BUILD_TYPE=Release \
		-D CMAKE_INSTALL_PREFIX=/usr \
		-D CMAKE_INSTALL_LIBDIR=lib \
		-S . \
		-B build
	cmake --build build
}

package() {
	cd "${srcdir}/${pkgname}-${pkgver}"
	DESTDIR="${pkgdir}" cmake --install build

	install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}

pre_install() {
	log "Iniciando instalação"
}

post_install() {
	log "Finalizando instalação"
}

pre_upgrade() {
	log "Iniciando upgrade"
}

post_upgrade() {
	log "Finalizando upgrade"
}
