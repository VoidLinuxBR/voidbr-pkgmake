pkgname=noctalia-qs
pkgver=0.0.12
pkgrel=1
pkgdesc='Custom fork of Quickshell powering Noctalia Shell'
arch=(x86_64 aarch64)
url="https://github.com/noctalia-dev/noctalia-qs"
license=('LGPL-3.0-only')
depends=(
    libgcc
    glibc
    hicolor-icon-theme
    jemalloc
    libdrm
    libglvnd
    libpipewire
    libxcb
    mesa
    pam
    qt6-base
    qt6-declarative
    qt6-svg
    qt6-wayland
    wayland
    polkit
)
makedepends=(
    cmake ninja git pkg-config cli11

    qt6-base-devel
    qt6-base-private-devel
    qt6-declarative-devel
    qt6-declarative-private-devel
    qt6-shadertools-devel
    qt6-wayland-devel

    wayland-devel
    wayland-protocols

    Vulkan-Headers
    SPIRV-Tools
    MesaLib-devel
    libdrm-devel

    pipewire-devel
    polkit-devel
    pam-devel
    libbluetooth-devel
    upower-devel
    NetworkManager-devel

    jemalloc-devel
)

#provides=("quickshell" "quickshell-git")
#conflicts=(quickshell quickshell-git)
options=(!debug)
_archive="$pkgname-$pkgver"
source=("$_archive.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('5de37541537307d141618aa0d782d3c34e42a6ad21c73533cce80c0e71ee9693')

build() {
    cd "$_archive"
    local cmake_options=(
        -D CMAKE_BUILD_TYPE=Release
        -D DISTRIBUTOR="Arch Linux"
        -D DISTRIBUTOR_DEBUGINFO_AVAILABLE=Yes
        -D CRASH_REPORTER=Off
        -D CMAKE_INSTALL_PREFIX=/usr
        -D INSTALL_QML_PREFIX=lib/qt6/qml
    )
    cmake -G Ninja -B build -Wno-dev "${cmake_options[@]}"
    cmake --build build
}

package() {
    cd "$_archive"
    DESTDIR="$pkgdir" cmake --install build
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

pre_install() {
  log "Iniciando instalação"
}

post_install() {
  log "Finalizando instalação"
}

pre_upgrade() {
  log "Iniciando upgrade"
}

post_upgrade() {
  log "Finalizando upgrade"
}


