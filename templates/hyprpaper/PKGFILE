# Maintainer: Vilmar Catafesta <vcatafesta@gmail.com>

pkgname=hyprpaper
pkgver=0.8.4
pkgrel=3
pkgdesc='a blazing fast wayland wallpaper utility with IPC controls'
arch=(x86_64)
url="https://github.com/hyprwm/$pkgname"
license=(BSD-3-Clause)
depends=(
	cairo
	file
	glibc
	libgcc
	libstdc++
	hyprgraphics
	hyprlang
	hyprtoolkit
	hyprutils
	hyprwayland-scanner
	hyprwire
	libglvnd
	pango
	wayland
)
makedepends=(
	pkgconf
	hyprwayland-scanner
	hyprwire
	hyprland-protocols
	wayland-protocols
	cmake
	xorgproto
	cairo-devel
	file-devel
	libjpeg-turbo-devel
	libwebp-devel
	hyprgraphics
	hyprutils
	hyprlang
	hyprtoolkit
	hyprwire
	pango-devel
	wlroots-devel
)
_archive="$pkgname-$pkgver"
source=("$url/archive/v$pkgver/$_archive.tar.gz")
sha256sums=('4912c7aede303918f38a3fc6b294429e2d541b639ebba67bcab58d1d367ea360')

prepare() {
  cd "$_archive"

  patch -Np1 -i ../../patches/fix-append-range.patch
  patch -Np1 -i ../../patches/02-fix-musl-cstring.patch
}

build() {
	cd "$_archive"
	cmake -B build \
		-D CMAKE_INSTALL_PREFIX=/usr \
		-D CMAKE_INSTALL_LIBDIR=lib \
		-D CMAKE_BUILD_TYPE=Release
	make protocols
	cmake --build build
}

package() {
	cd "$_archive"
	DESTDIR="$pkgdir" cmake --install build
	install -Dm0644 -t "$pkgdir/usr/share/licenses/$pkgname" LICENSE
}

pre_install() {
	log "Iniciando instalação"
}

post_install() {
	log "Finalizando instalação"
}

pre_upgrade() {
	log "Iniciando upgrade"
}

post_upgrade() {
	log "Finalizando upgrade"
}
