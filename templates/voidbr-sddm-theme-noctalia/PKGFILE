pkgname=voidbr-sddm-theme-noctalia
pkgver=r24.05d3761
pkgrel=2
pkgdesc="a theme designed to complement the Noctalia Shell experience."
arch=('any')
url="https://github.com/mda-dev/noctalia-sddm-theme"
license=('MIT')
depends=('sddm' 'qt5-declarative' 'qt5-quickcontrols2' 'qt5-graphicaleffects' 'qt5-svg')
makedepends=('git')
optdepends=('jq: for the sync-shell-wallpaper.sh script')
provides=()
conflicts=()
source=("git+$url.git")
sha256sums=('SKIP')

pkgver() {
	cd "$srcdir/noctalia-sddm-theme"
	printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
	install -dm755 "$pkgdir/usr/share/sddm/themes/noctalia"

	cd "$srcdir/noctalia-sddm-theme"
	cp -r * "$pkgdir/usr/share/sddm/themes/noctalia/"

	# Remove the installer directory as it is not needed for the package
	rm -rf "$pkgdir/usr/share/sddm/themes/noctalia/installer"

	# Ensure executable permission for the sync script
	chmod +x "$pkgdir/usr/share/sddm/themes/noctalia/sync-shell-wallpaper.sh"

	install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}

post_install() {
	echo ":: Setting permissions..."
	# Allow all users to write to theme.conf so Noctalia Shell can sync colors
	# Security Note: This makes the file world-writable.
	chmod 666 /usr/share/sddm/themes/noctalia/theme.conf

	echo ":: Configuration Instructions:"
	echo "   To enable color syncing with Noctalia Shell, add the following to"
	echo "   your ~/.config/noctalia/user-templates.toml:"
	echo ""
	echo "      [templates.sddm]"
	echo "      input_path = \"/usr/share/sddm/themes/noctalia/theme.template.conf\""
	echo "      output_path = \"/usr/share/sddm/themes/noctalia/theme.conf\""
	echo ""
	echo "   The wallpaper sync script is located at:"
	echo "   /usr/share/sddm/themes/noctalia/sync-shell-wallpaper.sh"
}

post_upgrade() {
	post_install
}
