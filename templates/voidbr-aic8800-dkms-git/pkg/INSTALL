set -e


post_install () 
{ 
    dkms add /usr/src/aic8800-r10.0af2cea;
    dkms build -m aic8800 -v r10.0af2cea;
    dkms install -m aic8800 -v r10.0af2cea;
    dkms status;
    depmod -a;
    modprobe aic8800_fdrv
}

ACTION="$1"
action="$1"
PKGNAME="$2"
pkgname="$2"
VERSION="$3"
pkgver="$3"
UPDATE="$4"
update="$4"

case "$ACTION" in
pre)
  :
  ;;
post)
  if [ "$UPDATE" = "yes" ]; then
    post_install
  else
    post_install
  fi
  ;;
esac
