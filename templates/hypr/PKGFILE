package() {
  local dirs=("usr" "etc" "opt")
  #   echo "DESTDIR=$DESTDIR"
  #   echo "pkgdir=$pkgdir"
  #   echo "srcdir=$srcdir"
  #   echo "_pkgsrc=$_pkgsrc"

  cd $srcdir
  for dir in "${dirs[@]}"; do
    if [ -d "${dir}" ]; then
      cp -a "${dir}" "$DESTDIR/"
    fi
  done
}

