#source=("$_archive.tar.gz::$url/releases/download/v$pkgver/source-v$pkgver.tar.gz")
source=("https://github.com/hyprwm/Hyprland/releases/download/v${pkgver}/source-v${pkgver}.tar.gz")
sha256sums=('10cdda47e6a42e603a646ffda89c9fca0628c3a8211e2fbbee02f6282effe30b')

prepare() {
	cd "$_archive"

	patch -Np1 -i ../../patches/01-fix-string-view-conversion.patch
	patch -Np1 -i ../../patches/02-fix-monitor-mode-sorting.patch
	patch -Np1 -i ../../patches/03-fix-xcb-connection-cast.patch
	patch -Np1 -i ../../patches/04-replace-embed-with-include.patch
	patch -Np1 -i ../../patches/05-fix-musl.patch
	patch -Np1 -i ../../patches/06-require-system-glaze.patch

	xxd -i -n EXAMPLE_CONFIG_BYTES_LUA \
		example/hyprland.lua \
		>src/config/lua/example_config_lua_data.h
}

build() {
	cd "$_archive"

	cmake -B build \
		-D CMAKE_BUILD_TYPE=Release \
		-D CMAKE_INSTALL_PREFIX=/usr \
		-D CMAKE_INSTALL_LIBDIR=lib \
		-D NO_SYSTEMD=ON \
		-D NO_SYSTEMD:BOOL=true \
		-D glaze_DIR:PATH=/usr/share/glaze \
		-D glaze_DIR=/usr/share/glaze

	cmake --build build
}

package() {
	cd "$_archive"

	DESTDIR="$pkgdir" cmake --install build

	install -Dm644 LICENSE \
		"$pkgdir/usr/share/licenses/$pkgname/LICENSE"

	install -d "$pkgdir/usr/include/hyprland"
	install -d "$pkgdir/usr/include/hyprland/protocols"
	install -d "$pkgdir/usr/share/pkgconfig"

	cmake --build build --target generate-protocol-headers

	find src \
		\( -name '*.hpp' -o -name '*.h' -o -name '*.inc' \) \
		-exec install -Dm644 "{}" "$pkgdir/usr/include/hyprland/{}" \;

	install -Dm644 protocols/*.h* \
		-t "$pkgdir/usr/include/hyprland/protocols"

	install -Dm644 build/hyprland.pc \
		"$pkgdir/usr/share/pkgconfig/hyprland.pc"
}

pre_install() {
	log "Iniciando instalação"
}

post_install() {
	log "Finalizando instalação"
}

pre_upgrade() {
